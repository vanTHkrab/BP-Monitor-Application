# Full GraphQL endpoint of the NestJS API gateway, INCLUDING the /graphql path.
# - When unset in Expo Go, the app falls back to the LAN host the bundler is
#   served from + ":3000/graphql".
# - In a release/EAS build there is no Expo host, so this MUST be set.
#
# Examples:
#   EXPO_PUBLIC_API_URL=http://192.168.1.10:3000/graphql   # local LAN dev
#   EXPO_PUBLIC_API_URL=http://10.0.2.2:3000/graphql       # Android emulator → host
#   EXPO_PUBLIC_API_URL=https://api.example.com/graphql    # production
EXPO_PUBLIC_API_URL=