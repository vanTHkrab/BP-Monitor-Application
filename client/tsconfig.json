  {
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
      "jsx": "react-jsx",
      "strict": true,
      "types": ["jest", "node"],
      "paths": {
        "@/*": [
          "./*"
        ]
      }
    },
    "include": [
      "**/*.d.ts",
      "**/*.ts",
      "**/*.tsx",
      ".expo/types/**/*.ts",
      "expo-env.d.ts",
      "nativewind-env.d.ts"
    ]
  }