{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Bash(git * main)"
    ],
    "allow": [
      "Bash(pnpm exec *)",
      "Bash(echo \"EXIT: $?\")",
      "Bash(cat ./client/app/(tabs)/*)",
      "Read(./client/app/(tabs)/**)"
    ]
  }
}
