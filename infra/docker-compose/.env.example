# PostgreSQL
POSTGRES_USER=bpmonitor
POSTGRES_PASSWORD=change-me-in-real-env
POSTGRES_DB=bpmonitor

# API Gateway reads this — keep host = "postgres" (the service name) when running in compose
DATABASE_URL=postgresql://bpmonitor:change-me-in-real-env@postgres:5432/bpmonitor?schema=public

# Auth
JWT_SECRET=replace-with-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# Web
NEXT_PUBLIC_API_URL=http://localhost:3000/graphql

# nginx + certbot (prod only — docker-compose.prod.yml)
# Domain the nginx reverse proxy terminates TLS for and issues the
# Let's Encrypt certificate against. Must have a DNS A (and/or AAAA) record
# pointing at this host's public IP *before* running
# infra/scripts/init-letsencrypt.sh — Let's Encrypt validates ownership by
# making an inbound HTTP request to this domain on port 80.
DOMAIN_NAME=example.com
# Email Let's Encrypt sends expiry/problem notices to. Required by certbot;
# not published anywhere public.
CERTBOT_EMAIL=admin@example.com
# Set to 1 to request from Let's Encrypt's staging CA instead of production
# while testing the bootstrap flow. Staging certs are untrusted by browsers
# but exempt from the production CA's strict rate limits — use this first
# on a new domain, confirm the flow works, then re-run without it. See
# infra/README.md "First-time cert issuance".
CERTBOT_STAGING=0

# AI service — public R2 base URL hosting the OCR model artifacts
# (yolo11n.onnx, crnn.onnx, cnn_2ch_distilled_*_int8.onnx, templates.npz).
# docker-entrypoint.sh refuses to start if this is the placeholder value.
AI_MODELS_R2_BASE_URL=https://REPLACE_ME.r2.dev/bp-monitor/models

# S3-compatible storage (consumed by api-gateway's StorageModule)
# Production target is Cloudflare R2. For staging on EC2 we point at
# Supabase Cloud Storage's S3 protocol endpoint — same env shape, no
# code change needed. Generate the access keys under
# Supabase dashboard → Project Settings → Storage → S3 Connection.
# These are NOT the anon / service_role JWT keys.
#
# Staging (Supabase Cloud) example:
#   S3_PROVIDER=supabase
#   S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
#   S3_BUCKET_NAME=bp-monitor-staging
#   S3_DEFAULT_REGION=ap-southeast-1
#   S3_USE_PATH_STYLE_ENDPOINT=true
#   S3_PUBLIC_BASE_URL=https://<project-ref>.supabase.co/storage/v1/object/public/bp-monitor-staging
#
# Production (Cloudflare R2) example:
#   S3_PROVIDER=r2
#   S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   S3_BUCKET_NAME=bp-monitor
#   S3_DEFAULT_REGION=auto
#   S3_USE_PATH_STYLE_ENDPOINT=true
#   S3_PUBLIC_BASE_URL=https://cdn.example.com
S3_PROVIDER=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_DEFAULT_REGION=
S3_BUCKET_NAME=
S3_ENDPOINT=
S3_USE_PATH_STYLE_ENDPOINT=
S3_PUBLIC_BASE_URL=
