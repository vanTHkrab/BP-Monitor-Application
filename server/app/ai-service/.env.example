# ai-service local-dev env. Copy to .env and fill in real values.
#
# Public R2 base URL hosting the OCR model artifacts (*.onnx, templates.npz).
# Both the Docker entrypoint (docker-entrypoint.sh) and the local-dev fetcher
# (`uv run python -m ai_service.scripts.fetch_models`) download from
# $AI_MODELS_R2_BASE_URL/<filename> and verify against models/EXPECTED_HASHES.json.
#
# The placeholder below is rejected at start time on purpose — replace it
# with the real public R2 URL before the first run. crnn.pt is kept in R2 as
# a training-source artifact only and is NOT fetched at runtime.
AI_MODELS_R2_BASE_URL=https://REPLACE_ME.r2.dev/bp-monitor/models
