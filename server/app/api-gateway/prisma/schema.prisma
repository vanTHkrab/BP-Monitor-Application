// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  moduleFormat = "cjs"
  output       = "../src/prisma/generated"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────── Enums ────────────────────────

enum UserRole {
  caregiver
  developer
  patient
}

enum Gender {
  male
  female
  other
}

enum AlertLevel {
  warning
  critical
}

enum BpStatus {
  low
  normal
  elevated
  high
  critical
}

enum PostCategory {
  general
  experience
  qa
}

enum RelationshipType {
  parent
  child
  spouse
  sibling
  friend
  caregiver_professional
  other
}

// ──────────────────────── Models ────────────────────────

model User {
  id                String    @id @default(uuid()) @db.Uuid
  email             String?   @unique @db.VarChar(255)
  firstname         String    @db.VarChar(100)
  lastname          String    @db.VarChar(100)
  phone             String    @unique @db.VarChar(30)
  passwordHash      String    @map("password_hash") @db.VarChar(255)
  role              UserRole  @default(patient)
  dob               DateTime? @db.Date
  gender            Gender?
  weight            Float?
  height            Float?
  congenitalDisease String?   @map("congenital_disease") @db.VarChar(255)
  avatar            String?   @db.VarChar(512)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  images           Image[]
  alerts           Alert[]
  caregiverLinks   CaregiverPatient[]     @relation("CaregiverUser")
  patientLinks     CaregiverPatient[]     @relation("PatientUser")
  readings         BloodPressureReading[]
  posts            Post[]
  postComments     PostComment[]
  postCommentLikes PostCommentLike[]
  postLikes        PostLike[]
  sessions         UserSession[]

  @@map("users")
}

model UserSession {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  deviceLabel  String?   @map("device_label") @db.VarChar(255)
  userAgent    String?   @map("user_agent") @db.VarChar(1024)
  isActive     Boolean   @default(true) @map("is_active")
  revokedAt    DateTime? @map("revoked_at")
  lastActiveAt DateTime  @default(now()) @map("last_active_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([createdAt])
  @@map("user_sessions")
}

model CaregiverPatient {
  caregiverId  String           @map("caregiver_id") @db.Uuid
  patientId    String           @map("patient_id") @db.Uuid
  relationship RelationshipType
  createdAt    DateTime         @default(now()) @map("created_at")

  caregiver User @relation("CaregiverUser", fields: [caregiverId], references: [id], onDelete: Cascade)
  patient   User @relation("PatientUser", fields: [patientId], references: [id], onDelete: Cascade)

  @@id([caregiverId, patientId])
  @@index([patientId])
  @@map("caregiver_patient")
}

model Image {
  id                Int      @id @default(autoincrement())
  userId            String   @map("user_id") @db.Uuid
  s3Key             String   @unique @map("s3_key") @db.VarChar(512)
  deviceName        String?  @map("device_name") @db.VarChar(255)
  imageQualityScore Float?   @map("image_quality_score")
  readingId         Int?     @unique @map("reading_id")
  uploadedAt        DateTime @default(now()) @map("uploaded_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")

  user    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reading BloodPressureReading? @relation(fields: [readingId], references: [id], onDelete: SetNull)

  @@index([userId, uploadedAt(sort: Desc)])
  @@map("images")
}

model Alert {
  id           Int        @id @default(autoincrement())
  userId       String     @map("user_id") @db.Uuid
  bpReadingId  Int        @map("bp_reading_id")
  alertMessage String     @map("alert_message") @db.VarChar(500)
  alertLevel   AlertLevel @map("alert_level")
  readAt       DateTime?  @map("read_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @default(now()) @updatedAt @map("updated_at")

  user    User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  reading BloodPressureReading @relation(fields: [bpReadingId], references: [id], onDelete: Cascade)

  @@index([bpReadingId])
  @@index([userId, readAt, createdAt(sort: Desc)])
  @@map("alerts")
}

model BloodPressureReading {
  id         Int      @id @default(autoincrement())
  userId     String   @map("user_id") @db.Uuid
  clientId   String?  @unique @map("client_id") @db.VarChar(255)
  systolic   Int
  diastolic  Int
  pulse      Int
  status     BpStatus
  measuredAt DateTime @map("measured_at")
  notes      String?  @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  images Image[]
  alerts Alert[]

  @@index([userId, measuredAt(sort: Desc)])
  @@map("blood_pressure_readings")
}

// ──────────────────────── New Models ────────────────────────

model Post {
  id        Int          @id @default(autoincrement())
  userId    String       @map("user_id") @db.Uuid
  clientId  String?      @unique @map("client_id") @db.VarChar(255)
  content   String       @db.Text
  category  PostCategory @default(general)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime?    @map("updated_at")

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes    PostLike[]
  comments PostComment[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([category])
  @@map("posts")
}

model PostComment {
  id        Int       @id @default(autoincrement())
  postId    Int       @map("post_id")
  userId    String    @map("user_id") @db.Uuid
  parentId  Int?      @map("parent_id") // null = top-level comment
  content   String    @db.Text
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @map("updated_at")

  post    Post              @relation(fields: [postId], references: [id], onDelete: Cascade)
  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  PostComment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies PostComment[]     @relation("CommentReplies")
  likes   PostCommentLike[]

  @@index([postId, createdAt])
  @@index([userId])
  @@index([parentId])
  @@map("post_comments")
}

model PostCommentLike {
  userId    String   @map("user_id") @db.Uuid
  commentId Int      @map("comment_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment PostComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
  @@map("post_comment_likes")
}

model PostLike {
  userId    String   @map("user_id") @db.Uuid
  postId    Int      @map("post_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@map("post_likes")
}
