{
  "expo": {
    "name": "BP-Mobile",
    "slug": "BP-Mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bpmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "แอปนี้ต้องการใช้กล้องเพื่อถ่ายภาพหน้าจอเครื่องวัดความดัน",
        "NSPhotoLibraryUsageDescription": "แอปนี้ต้องการเข้าถึงคลังรูปเพื่อเลือกรูปเครื่องวัดความดัน",
        "NSPhotoLibraryAddUsageDescription": "แอปนี้ต้องการบันทึกรูปลงคลังรูป (ถ้าคุณเลือกบันทึก)"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.ok999p.BPMobile"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "แอปนี้ต้องการใช้กล้องเพื่อถ่ายภาพหน้าจอเครื่องวัดความดัน"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "แอปนี้ต้องการเข้าถึงคลังรูปเพื่อเลือกรูปเครื่องวัดความดัน",
          "cameraPermission": "แอปนี้ต้องการใช้กล้องเพื่อถ่ายภาพหน้าจอเครื่องวัดความดัน"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
