# ===== S3 / Object Storage =====
# Provider determines client construction (cloudflare | aws | minio | digitalocean)
S3_PROVIDER=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_DEFAULT_REGION=
S3_BUCKET_NAME=
S3_ENDPOINT=
S3_USE_PATH_STYLE_ENDPOINT=

# ===== API Gateway (NestJS / GraphQL) =====
# Base URL of the api-gateway. Used by lib/gateway.ts for health probes.
GATEWAY_URL=http://localhost:3000

# ===== AI Service (FastAPI) =====
# Used by lib/ai-service.ts for the /health probe.
AI_SERVICE_URL=http://localhost:8000

# ===== Redis =====
# Either provide REDIS_URL or REDIS_HOST/REDIS_PORT. URL wins if both set.
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== Database (Postgres) =====
# Same connection string as the api-gateway. Read-only role recommended for the
# dashboard, but any user with SELECT is enough for the health probes used here.
DATABASE_URL=
